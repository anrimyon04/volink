<div class="blank1">
  <div class="blank2">
    <h2>マイページ</h2>
      <p>名前 : <%= @user.name %></p>
      <p>メールアドレス : <%= @user.email %></p>
      <p>プロフィール : <%= @user.profile %></p>
    <% if current_user.id == @user.id %>
    <%= link_to "編集する", edit_user_registration_path, class: "btn-flat-border" %>
  <% end %>
  <div class="user-posts-section">
    <h3>投稿一覧</h3>
    <% @user.tweets.each do |t| %>
    <%= t.user.name %>
    <%= t.body %>
  <% end %>
  <div class="user-likes-section">
    <h3>いいねした投稿一覧</h3>
    <% @user.liked_tweets.each do |t| %>
    <%= t.user.name %>
    <%= t.body %>
  <% end %>

  <% if @user.image.attached? %>
    <%= image_tag  @user.image, size: '250x200'%>
  <% end %>
  <%= link_to "Tweet一覧に戻る", tweets_path, class: "btn-flat-border" %>
</div>


  <div class="new-post-header-image"> 
    <%= image_tag "6.jpg", alt: "新規投稿バナー" %> 
  </div>
</div>

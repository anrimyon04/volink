<div class="tag-search-container"> 
  <h2>ボランティア投稿を探す</h2>
  <h4>ジャンルから検索<h4>
  <%= form_tag({controller:"tweets",action:"index"}, method: :get) do %>
  <%= text_field_tag :tag %>
<% end %>
  
<%= form_tag({controller:"tweets",action:"index"}, method: :get) do %>
  <div class="tag-checkboxes">
      <% Tag.all.each do |tag| %>
        <span class="tag-checkbox-item"> 
          <%= check_box_tag "tag_ids[]", tag.id, false, id: "tag_#{tag.id}" %> 
          <%= label_tag "tag_#{tag.id}", tag.name %>
        </span>
      <% end %>
  </div>
    <%= submit_tag '検索' , class: "btn-flat-border"%>
  <% end %>
</div>

<div class="search-section">
  <h4>キーワードから検索</h2>
  <%= form_tag({controller:"tweets",action:"index"}, method: :get) do %>
   <%= text_field_tag :search, nil, class: "keyword-search-input" %>
   <%= submit_tag '検索', class: "btn-flat-border" %>
  
  <% end %>
</div>

<div class="posts-list-container">
<h2>投稿一覧</h2>
  <h4>みんなのボランティア経験を見てみよう<h4> 
  <div class="tweets-container">
    <% @tweets.each do |t| %>
      <div class="tweet-card"> 
        <% if t.image.attached? %>
          <%= image_tag t.image, class: "tweet-card-image" %> 
        <% else %>
          <div class="tweet-card-placeholder-image"></div>
        <% end %>

        <div class="tweet-card-content">
        <% if t.title.present? %>
            <h4 class="tweet-card-volunteer-name"><%= t.title %></h4>
          <% end %>

          <p class="tweet-card-body"><%= t.body %></p>
          <% if t.respond_to?(:tags) && t.tags.present? %>
            <div class="tweet-card-categories">
              <% t.tags.each do |tag| %>
                <span class="tweet-card-category-tag"><%= tag.name %></span> 
              <% end %>
            </div>
          <% end %> 

          <div class="tweet-card-meta"> 
            <%= link_to t.user.name, user_path(t.user.id), class: "tweet-card-username" %>
            <span class="tweet-card-date"><%= t.created_at.strftime("%Y-%m-%d %H:%M") %></span> 
          </div>

          <div class="tweet-card-actions"> 
            <div class="tweet-card-likes"> 
              <% if user_signed_in? %>
                <% if current_user.already_liked?(t) %>
                  <%= link_to tweet_like_path(id: t.id, tweet_id: t.id), data: { turbo_method: :delete } do %>
                    <i class="fas fa-heart"></i><span><%= t.likes.count %></span>
                    <span class="like-text">いいねを取り消す</span>
                  <% end %>
                <% else %>
                  <%= link_to tweet_likes_path(id: t.id, tweet_id: t.id), data: { turbo_method: :post }  do %>
                    <i class="fas fa-heart"></i><span><%= t.likes.count %></span>
                    <span class="like-text">いいね</span>
                  <% end %>
                <% end %>
              <% else %> 
                <i class="fas fa-heart"></i><span><%= t.likes.count %></span>
                <span class="like-text">いいねの数 = </span>
              <% end %>
            </div>

            <div class="tweet-card-buttons"> 
              <%= link_to "詳細", tweet_path(t.id), class: "btn-flat-border btn-small" %>
              <%= link_to "編集", edit_tweet_path(t.id), class: "btn-flat-border btn-small" %>
              <%= link_to "削除", tweet_path(t.id),  data: { turbo_method: :delete } , class: "btn-flat-border btn-small"%>
            </div>
          </div> 

        </div> 

      </div> 
    <% end %> 
  </div> 
  <div class="pagination-section">
    <%= page_entries_info @tweets %>
    <%= paginate @tweets %>
  </div>
</div> 





